{
  "name": "bitcoin-supply",
  "version": "2.0.0",
  "description": "Bitcoin supply explorer",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node esbuild.config.js",
    "dev": "tsx watch src/server.ts",
    "etl": "tsx src/etl/index.ts",
    "snapshot": "tsx src/etl/index.ts snapshot",
    "migrate": "node -e \"require('./migrations/run.js')\"",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "bitcoin-core": "^3.0.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "marked": "^9.1.0",
    "nouislider": "^15.7.1",
    "pg": "^8.11.3",
    "pug": "^3.0.2",
    "redis": "^4.6.10",
    "zeromq": "^6.0.0-beta.19"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/pug": "^2.0.10",
    "esbuild": "^0.19.9",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
