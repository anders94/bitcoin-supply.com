RPCHOST=localhost
RPCPORT=8332
RPCUSERNAME=bitcoin
RPCPASSWORD=your_rpc_password_here
RPCNETWORK=mainnet
ZMQADDRESS=tcp://localhost:28332

PGHOST=localhost
PGPORT=5432
PGDATABASE=bitcoin_supply
PGUSER=bitcoin_supply
PGPASSWORD=your_db_password_here

# The web server caches here AND subscribes for block events; the ETL only
# publishes them. Pub/sub is the only part that needs both processes on the SAME
# instance — the caching is happy on a local one. Set REDISPASSWORD whenever
# Redis listens past loopback: binding to another interface takes it out from
# behind protected-mode. Leave empty for a loopback-only instance.
REDISHOST=127.0.0.1
REDISPORT=6379
REDISPASSWORD=

HOST=0.0.0.0
PORT=3000
ETL_CONCURRENCY=8
ETL_BATCH_SIZE=1000
