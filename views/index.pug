extends layout

block content
  // Hero Section
  .hero.fade-in
    .hero-subtitle CANONICAL BITCOIN SUPPLY LEDGER
    .hero-title.btc-amount #{helpers.format(block.current_total_supply/100000000, 8)} BTC
    p.text-secondary.mb-4
      | Circulating Supply • Block
      a(href='/block/'+block.block_number).text-orange.block-number= helpers.format(block.block_number)

    // Progress Bar
    .supply-progress-container
      .supply-progress-label
        span Released
        span.supply-progress-value #{((block.current_total_supply/total_possible_supply)*100).toFixed(3)}%
      .progress
        .progress-bar(role='progressbar', style=`width: ${((block.current_total_supply/total_possible_supply)*100).toFixed(3)}%`, aria-valuenow=((block.current_total_supply/total_possible_supply)*100).toFixed(3), aria-valuemin='0', aria-valuemax='100')

  // Key Metrics Grid
  .metrics-grid
    .metric-card
      .metric-value.btc-amount #{helpers.format(total_possible_supply/100000000000000, 4)}M
      .metric-label Total Expected Supply
    .metric-card
      .metric-value.text-danger.btc-amount #{helpers.format(total_lost/100000000, 4)}
      .metric-label Permanently Lost
    .metric-card
      .metric-value.btc-amount #{helpers.format(block.blocks_till_halving, 0)}
      .metric-label Blocks Till Halving

  // Supply Progress Chart
  .chart-container
    canvas#supplyProgressChart

  // Current Block Info Card
  .card.mb-4
    .card-header
      h3.mb-0
        | Block
        a(href='/block/'+block.block_number).text-orange.block-number= helpers.format(block.block_number)
    .card-body
      .row
        .col-md-6.mb-3
          .metric-label New Supply This Block
          .btc-amount.text-orange #{helpers.format(block.allowed_supply/100000000, 8)} BTC
        .col-md-6.mb-3
          .metric-label Timestamp
          .timestamp #{new Date(block.block_timestamp).toLocaleDateString('en-us', {year: 'numeric', month: 'long', day: 'numeric', hour: 'numeric', minute: 'numeric', timeZone: 'utc'})} UTC
        if block.miner_loss != 0
          .col-md-6.mb-3
            .metric-label Miner Loss
            .btc-amount.text-danger #{helpers.format(block.miner_loss/100000000, 8)} BTC
        if block.transactional_loss != 0
          .col-md-6.mb-3
            .metric-label Transactional Loss
            .btc-amount.text-danger #{helpers.format(block.transactional_loss/100000000, 8)} BTC
      .mt-3
        a.btn.btn-primary(href='/block/'+(Number(block.block_number)-1)) ← Previous Block
        |
        a.btn.btn-outline-success(href='/block/'+block.block_number) View Block Details →

  // Loss Timeline Chart
  .chart-container
    canvas#lossTimelineChart

  // Latest Activity Section
  .row.mt-4
    .col-lg-6.mb-4
      .card
        .card-header
          h3.mb-0 Recent Supply Losses
        .card-body.p-0
          .table-responsive
            table.table.table-hover.mb-0
              thead
                tr
                  th.text-end Block
                  th Permanently Lost
                  th When
              tbody
                each loss_block in latest_losses
                  tr
                    td.text-end
                      a(href='/block/'+loss_block.block_number).block-number= helpers.format(loss_block.block_number)
                    td.btc-amount.text-danger #{helpers.format((loss_block.allowed_supply - loss_block.new_supply) / 100000000, 8)} BTC
                    td
                      span.timestamp.d-inline-block(tabindex=0, data-bs-toggle='tooltip', data-bs-placement='top', title=moment(loss_block.block_timestamp).format('YYYY-MM-DD HH:mm:ss'))= moment(loss_block.block_timestamp).from()
        .card-body.text-center.border-top
          a.btn.btn-sm.btn-outline-success(href='/losses') View Complete Loss History →

    .col-lg-6.mb-4
      .card
        .card-header
          h3.mb-0 Largest Supply Events
        .card-body.p-0
          .table-responsive
            table.table.table-hover.mb-0
              thead
                tr
                  th.text-end Block
                  th Permanently Lost
                  th Date
              tbody
                each loss_block in biggest_losses
                  tr
                    td.text-end
                      a(href='/block/'+loss_block.block_number).block-number= helpers.format(loss_block.block_number)
                    td.btc-amount.text-danger #{helpers.format((loss_block.allowed_supply - loss_block.new_supply) / 100000000, 8)} BTC
                    td.timestamp #{moment(loss_block.block_timestamp).format('YYYY-MM-DD')}

  // Halving Schedule
  .card.mb-4
    .card-header
      h3.mb-0 Halving Schedule
    .card-body.p-0
      .table-responsive
        table.table.table-hover.mb-0.halving-table
          thead
            tr
              th.text-end Block
              th Supply Per Block
              th Date
              th Status
          tbody
            tr.halving-complete
              td.text-end
                a(href='/block/0').block-number 0
              td.btc-amount 50.00000000 BTC
              td 2009-01-03
              td
                span.badge.badge-success Complete
            tr.halving-complete
              td.text-end
                a(href='/block/210000').block-number 210,000
              td.btc-amount 25.00000000 BTC
              td 2012-11-28
              td
                span.badge.badge-success Complete
            tr.halving-complete
              td.text-end
                a(href='/block/420000').block-number 420,000
              td.btc-amount 12.50000000 BTC
              td 2016-07-09
              td
                span.badge.badge-success Complete
            tr.halving-complete
              td.text-end
                a(href='/block/630000').block-number 630,000
              td.btc-amount 6.25000000 BTC
              td 2020-05-11
              td
                span.badge.badge-success Complete
            tr.halving-complete
              td.text-end
                a(href='/block/840000').block-number 840,000
              td.btc-amount 3.12500000 BTC
              td 2024-04-20
              td
                span.badge.badge-success Complete
            tbody#halvingExpanded.collapsible-content
              tr.halving-future
                td.text-end
                  a(href='/block/unmined/1050000').block-number 1,050,000
                td.btc-amount 1.56250000 BTC
                td
                  span.text-muted ~2028
                td
                  span.badge.badge-warning Pending
              tr.halving-future
                td.text-end
                  a(href='/block/unmined/1260000').block-number 1,260,000
                td.btc-amount 0.78125000 BTC
                td
                  span.text-muted ~2032
                td
                  span.badge.badge-warning Pending
              tr.halving-future
                td.text-end
                  a(href='/block/unmined/1470000').block-number 1,470,000
                td.btc-amount 0.39062500 BTC
                td
                  span.text-muted ~2036
                td
                  span.badge.badge-warning Pending
              tr.halving-future
                td.text-end
                  a(href='/block/unmined/1680000').block-number 1,680,000
                td.btc-amount 0.19531250 BTC
                td
                  span.text-muted ~2040
                td
                  span.badge.badge-warning Pending
              tr.halving-future
                td.text-end
                  a(href='/block/unmined/1890000').block-number 1,890,000
                td.btc-amount 0.09765625 BTC
                td
                  span.text-muted ~2044
                td
                  span.badge.badge-warning Pending
              tr.halving-future
                td.text-end.text-muted 2,100,000+
                td.btc-amount.text-muted < 0.05 BTC
                td.text-muted 2048+
                td
                  span.badge.badge-warning Pending
    .card-body.text-center.border-top
      a.collapse-toggle#halvingToggle(onclick='toggleHalvings()')
        span#halvingToggleText ▼ Show All Future Halvings

  // Methodology Section
  .card.mb-4
    .card-header
      h3.mb-0 Methodology
      .text-secondary.mt-2.text-sm
        span.badge.badge-success.me-2 Open Source
        span.badge.badge-success.me-2 Auditable
        span.badge.badge-success Transparent
    .card-body
      p
        strong Bitcoin Supply tracks provably lost bitcoin through open-source detection protocols.
        | All loss determinations follow
        a(href='https://github.com/anders94/bitcoin-supply.com/blob/main/detectors/index.js', target='_blank', rel='noopener') publicly documented logic
        | . Protocol discussions occur in GitHub
        a(href='https://github.com/anders94/bitcoin-supply.com/issues', target='_blank', rel='noopener') issues
        | , with changes implemented through auditable
        a(href='https://github.com/anders94/bitcoin-supply.com/pulls', target='_blank', rel='noopener') pull requests
        | .

      p.mb-0
        | Bitcoin can be permanently lost through several mechanisms:
        strong unclaimed miner rewards
        | (e.g.,
        a(href='/block/501726') block 501,726
        |  where 12.5 BTC went unclaimed),
        strong unspendable transaction outputs
        | (e.g.,
        a(href='/transaction/03acfae47d1e0b7674f1193237099d1553d3d8a93ecc85c18c4bec37544fe386') 497 BTC made unspendable
        |  by the defunct MtGox exchange in
        a(href='/block/150951') block 150,951
        | ), and
        strong protocol-level anomalies
        | (e.g., the unspendable genesis block coinbase). All losses are cryptographically verifiable and irreversible.

block javascript
  script(src='/javascripts/charts.js')
  script.
    // Initialize tooltips
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    const tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
      return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // Initialize Supply Progress Chart
    const circulatingSupply = #{block.current_total_supply/100000000};
    const totalSupply = 21000000;
    BitcoinSupplyCharts.initSupplyProgressChart('supplyProgressChart', circulatingSupply, totalSupply);

    // Initialize Loss Timeline Chart
    const lossData = !{JSON.stringify(latest_losses.concat(biggest_losses).map(b => ({ block: b.block_number, amount: (b.allowed_supply - b.new_supply) / 100000000, date: b.block_timestamp })))};
    BitcoinSupplyCharts.initLossTimelineChart('lossTimelineChart', lossData);

    // Halving expansion toggle
    function toggleHalvings() {
      const expanded = document.getElementById('halvingExpanded');
      const toggleText = document.getElementById('halvingToggleText');

      if (expanded.classList.contains('active')) {
        expanded.classList.remove('active');
        expanded.style.maxHeight = '0';
        toggleText.textContent = '▼ Show All Future Halvings';
      } else {
        expanded.classList.add('active');
        expanded.style.maxHeight = expanded.scrollHeight + 'px';
        toggleText.textContent = '▲ Hide Future Halvings';
      }
    }
