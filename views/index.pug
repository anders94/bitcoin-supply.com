extends layout

block styles
  link(rel='stylesheet', href='/javascripts/dist/home.css')

block content
  //- hero
  .desktop-hero
    .hero-figures
      span.label EFFECTIVE SUPPLY · BTC
      .hero-num
        span.int#hero-int= ssr.eff.int
        span.dec#hero-dec .#{ssr.eff.dec}
      .redline.mobile-only#hero-redline −#{ssr.oocBtc} out of circulation · provably lost
    .hero-sub
      span.label.label--red OUT OF CIRCULATION
      span.figure.figure--red#hero-sub-ooc −#{ssr.oocBtc}
    .hero-sub
      span.label.label--purple Q-CAPTURED
      span.figure.figure--purple#hero-sub-q= ssr.q.captured
    .hero-aside
      | +#{btc8(supply.miner_never_claimed_sats)} BTC expected,
      br
      | never claimed by miners

  //- supply bar
  div(style='display:flex;flex-direction:column;gap:5px')
    .bar
      .bar__eff#bar-eff(style=`width:${ssr.effW}%`)
        .bar__hatch#bar-hatch(style=`width:${ssr.qW}%`)
      .bar__ooc#bar-ooc(style=`width:${ssr.oocW}%`)
      .bar__stripe
    .legend
      span
        i.sw-eff
        | EFFECTIVE
      span
        i.sw-ooc
        | OUT OF CIRC
      span
        i.sw-stripe
        | UNISSUED
      span
        i.sw-hatch
        | Q-CAPTURED
    .note.mobile-only +#{btc8(supply.miner_never_claimed_sats)} BTC expected but never claimed by miners — excluded from issued supply.

  .home-grid
    .col
      //- spectrum
      section.section.panel
        .section-head
          span.label WHAT COUNTS AS OUT OF CIRCULATION?
          span.section-value.section-value--red#spectrum-ooc −#{ssr.oocBtc}
        #spectrum-slider.slider
        .stops#spectrum-stops
          span(data-stop='0') NOTHING
          span.active(data-stop='1') PROVABLE
          span(data-stop='2') PROBABLE
          span(data-stop='3') DORMANT
          span(data-stop='4') EVERYTHING
        .inset#dormancy-panel(hidden)
          span.label.label--sub#dormancy-label DORMANCY THRESHOLD · ≥ 10Y
          #dormancy-slider.slider
          .stops.stops--year#dormancy-stops
            span(data-year='0') 1y
            span(data-year='1') 3y
            span(data-year='2') 5y
            span(data-year='3') 7y
            span.active(data-year='4') 10y
            span(data-year='5') 15y
            span(data-year='6') 20y
        .desc.desc--min#stop-desc Mathematically certain only: outputs spent to unspendable conditions. The default view.
        .rows#breakdown
          .row.row--head(data-group='provable')
            span PROVABLE
            span RULES 000–011
          each g in supply.breakdown.provable
            .row(data-group='provable')
              span= g.label
              span= btc8(g.sats)
          .row.row--head.dim(data-group='probable')
            span PROBABLE
            span RULES 012–013
          each g in supply.breakdown.probable
            .row.dim(data-group='probable')
              span= g.label
              span= btc8(g.sats)
          .row.row--head.dim(data-group='dormant')
            span DORMANT
            span RULE 014
          .row.dim(data-group='dormant')
            span#dormant-row-label Untouched ≥ 10y · incl. Satoshi-era
            span#dormant-row-value= ssr.dormantValue
          .row.dim(data-group='active', style='padding-bottom:6px')
            span#active-row-label Active UTXOs (moved &lt; 10y)
            span#active-row-value= ssr.activeValue
          .row.row--total
            span OUT OF CIRCULATION
            span#ooc-total #{ssr.oocBtc} · #{ssr.oocPct}

      //- top losses (below the fold on mobile)
      section.section.panel.section--tight
        span.label TOP LOSSES · ALL TIME
        .rows(style='font-size:10px')
          each e in topLosses
            .event-row
              span.rank= e.rank
              if e.href
                a.lbl(href=e.href)= e.label
              else
                span.lbl= e.label
              span.chip(class=ruleCategory(e.rule) === 'probable' ? 'chip--amber' : 'chip--red')= e.rule
              span.amt.amt--red −#{btc8(e.total_sats)}
              span.yr= e.year_label
        a.more-link(href='/losses') FULL LOSS HISTORY →

    .col
      //- quantum
      section.section.panel
        .section-head
          span.label QUANTUM ATTACK CAPTURE
          span.section-value.section-value--purple
            span#q-pct= ssr.q.pct
            |  of exposed
        .desc If a practical quantum computer existed, a rational attacker would break the largest exposed keys first. Sweep the capture.
        #quantum-slider.slider
        .slider-scale
          span NOTHING
          span MOST VALUABLE → LEAST VALUABLE OUTPUTS
          span ALL EXPOSED
        .rows
          .row
            span.k captured
            span.v--purple
              span#q-captured= ssr.q.captured
              |  BTC
          .row.row--dotted
            span.k keys broken
            span#q-keys= ssr.q.keys
          .row.row--dotted
            span.k smallest output worth breaking
            span#q-minworth= ssr.q.minWorth
          .row.row--dotted
            span.k effective supply after attack
            span#q-effafter= ssr.q.effAfter
        .note P2PK #{btc2(supply.quantum.p2pk_sats)} · EXPOSED P2PKH #{btc2(supply.quantum.exposed_pkh_sats)} · TOTAL #{btc2(supply.quantum.total_sats)}
        .note--italic A different cut through the same outputs — never added to the loss total. #[a(href='/quantum', style='color:var(--secondary)') Full quantum explorer →]

      //- recent losses
      section.section.panel.section--tight
        span.label RECENT PROVABLE LOSSES
        .rows(style='font-size:9.5px')
          each l in recentLosses
            .event-row
              a.txid(href=`/transaction/${l.tx_hash}`)= shortHash(l.tx_hash)
              span.chip.chip--red= ruleChip(l.loss_rules[0])
              span.amt −#{btc8(l.value_sats)}
              span.blk= num(l.block_number)

      //- halvings
      section.section.panel.section--tight
        span.label REWARD HALVINGS
        .rows(style='font-size:10px')
          each h in halvings
            .event-row(style=h.estimated ? 'color:var(--secondary)' : '')
              span(style='width:56px;color:var(--secondary)')= num(h.height)
              if h.estimated
                span(style='flex:1;font-style:italic') ~#{h.timestamp ? dateUtc(h.timestamp) : '—'} (est.)
              else
                span(style='flex:1')= h.timestamp ? dateTimeUtc(h.timestamp) : '—'
              span #{h.from_subsidy} → #{h.to_subsidy}
        span.note.note--tiny#freshness DATA #{dateTimeUtc(freshness)} · TIP #{num(supply.tip.height)}

block scripts
  script.
    window.__SUPPLY__ = !{supplyJson};
  script(src='/javascripts/dist/home.js', defer)
