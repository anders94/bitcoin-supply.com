doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= title + ' · bitcoin-supply'
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin)
    link(rel='stylesheet', href='https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap')
    link(rel='stylesheet', href='/stylesheets/ledger.css')
    block styles
  body
    header.site-header
      .wrap
        a.wordmark(href='/') BITCOIN·SUPPLY
        .header-right
          nav.header-nav
            a(href='/quantum') QUANTUM
            a(href='/losses') LOSSES
            a(href='/proposals') PROPOSALS
          form.header-search(action='/search', method='POST')
            input(type='search', name='query', placeholder='block · txid · address ⏎', autocomplete='off')
          #tip.tip(data-tip-height=tip.height, data-tip-ts=tip.timestamp)
            span.tip-dot
            span#tip-text #{num(tip.height)}
    main
      .wrap
        block content
    footer.site-footer
      .wrap
        a(href='/quantum') QUANTUM
        a(href='/losses') LOSSES
        a(href='/proposals') PROPOSALS
        span.spacer
        a.muted(href='/about') ABOUT
    script(src='/javascripts/dist/header.js', defer)
    block scripts
