doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= title + ' · bitcoin-supply'
    //- Guard against a stale server build that doesn't populate meta.
    - meta = (typeof meta === 'object' && meta) || {}
    meta(name='description', content=meta.description)
    link(rel='canonical', href=meta.url)
    meta(property='og:site_name', content='bitcoin-supply')
    meta(property='og:type', content=meta.type)
    meta(property='og:title', content=meta.ogTitle || (title + ' · bitcoin-supply'))
    meta(property='og:description', content=meta.description)
    meta(property='og:url', content=meta.url)
    meta(property='og:image', content=meta.image)
    meta(property='og:image:width', content='1200')
    meta(property='og:image:height', content='630')
    meta(property='og:image:alt', content=meta.imageAlt)
    meta(name='twitter:card', content='summary_large_image')
    meta(name='twitter:title', content=meta.ogTitle || (title + ' · bitcoin-supply'))
    meta(name='twitter:description', content=meta.description)
    meta(name='twitter:image', content=meta.image)
    meta(name='twitter:image:alt', content=meta.imageAlt)
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin)
    link(rel='stylesheet', href='https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap')
    link(rel='stylesheet', href='/stylesheets/ledger.css')
    script(async, src='https://www.googletagmanager.com/gtag/js?id=G-QR2SXVYGER')
    script.
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QR2SXVYGER');
    block styles
  body
    header.site-header
      .wrap
        a.wordmark(href='/') BITCOIN·SUPPLY
        .header-right
          nav.header-nav
            a(href='/quantum') QUANTUM
            a(href='/losses') LOSSES
            a(href='/proposals') PROPOSALS
          form.header-search(action='/search', method='POST')
            input(type='search', name='query', placeholder='block · txid · address ⏎', autocomplete='off')
          #tip.tip(data-tip-height=tip.height, data-tip-ts=tip.timestamp, tabindex='0', aria-describedby='tip-tooltip')
            span.tip-dot
            span#tip-text #{num(tip.height)}
            #tip-tooltip.tip-tooltip(role='tooltip')
              span.tip-tooltip-label LATEST INDEXED BLOCK
              | The newest block in this ledger, and how long since it was
              | mined. Indexing deliberately runs #{tip.lag} confirmations
              | behind the network tip, so a brief chain reorganization
              | can’t corrupt the running totals.
    main
      .wrap
        block content
    footer.site-footer
      .wrap
        a(href='/quantum') QUANTUM
        a(href='/losses') LOSSES
        a(href='/proposals') PROPOSALS
        span.spacer
        a.muted(href='/about') ABOUT
    script(src='/javascripts/dist/header.js', defer)
    block scripts
