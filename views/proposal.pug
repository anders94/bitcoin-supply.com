extends layout

block content
  div(style='display:flex;flex-direction:column;gap:4px')
    a.back-link(href='/proposals') ← ALL PROPOSALS
    span.label PROPOSAL #{id}
    span.page-title= heading
    div(style='display:flex;gap:6px')
      if category
        span.chip(class=chipClass, style='padding:1px 5px')= category
      span.chip.chip--gray(style='padding:1px 5px')= status

  if metaRows.length
    .rows(style='font-size:10px')
      each m, i in metaRows
        .row.row--dotted(style=i === metaRows.length - 1 ? 'border-bottom:1px dotted var(--dotted);padding:4px 0' : 'padding:4px 0')
          span.k= m.label
          span= m.value

  .proposal-body
    != content

  .pager
    if prev
      a(href=`/proposals/${prev.id}`) ← #{prev.id} #{prev.title.toUpperCase().slice(0, 24)}
    else
      span.disabled ← —
    if next
      a(href=`/proposals/${next.id}`) #{next.id} #{next.title.toUpperCase().slice(0, 24)} →
    else
      span.disabled — →
