extends layout

block content
  .page-head
    span.label PROPOSALS
    span.big #{proposals.length} classification rules
    span.desc Every figure on this site traces to a rule. Additions and changes happen by pull request; finalized proposals become detectors.

  .rows
    each p in proposals
      .loss-item
        .line1(style='align-items:baseline')
          span(style='color:var(--faded)')= p.id
          a.hash-link(href=`/proposals/${p.id}`, style='flex:1')= p.title
          span(style='font-size:9.5px;color:var(--secondary)')= p.scale
        div(style='display:flex;gap:6px;padding-left:26px')
          span.chip(class=p.chipClass)= p.category
          span.chip.chip--gray= p.status

  .pager(style='justify-content:flex-start;gap:6px')
    span(style='color:var(--faded);border:none') SUBMIT A PROPOSAL →
    a(href='https://github.com/anders94/bitcoin-supply.com-2', style='color:var(--secondary);border-bottom:1px solid var(--border)') github.com/anders94/bitcoin-supply.com-2
