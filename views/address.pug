extends layout

block content
  .page-head
    span.label ADDRESS
    span.hash= addr

  if isQuantumVulnerable
    .alert-inset
      span(style='color:var(--purple);font-weight:600') Quantum exposed:
      |  this address has revealed its public key in a prior spend. A sufficiently powerful quantum computer could derive the private key.
      if addrInfo && addrInfo.pubkey_hex
        br
        span.hash(style='font-size:8.5px;color:var(--faded)') pubkey #{addrInfo.pubkey_hex}

  .rows(style='font-size:10px')
    .row.row--dotted
      span.k balance
      span(style='font-weight:600') #{btc8(totalBalance)} BTC
    .row.row--dotted
      span.k utxos shown
      span= utxos.length
    .row.row--dotted
      span.k first seen block
      span= addrInfo ? num(addrInfo.first_seen_block) : '—'
    .row.row--dotted
      span.k last active block
      span= addrInfo ? num(addrInfo.last_active_block) : '—'

  section.section.section--tight
    span.label UTXOS
    .rows(style='font-size:10px')
      if utxos.length
        each u in utxos
          .event-row
            a.txid(href=`/transaction/${u.tx_hash}`) #{shortHash(u.tx_hash)} : #{u.output_index}
            a.blk(href=`/block/${u.block_number}`)= num(u.block_number)
            each rule in u.loss_rules
              span.chip(class=ruleCategory(rule) === 'probable' ? 'chip--amber' : ruleCategory(rule) === 'quantum' ? 'chip--purple' : 'chip--red')= ruleChip(rule)
            if u.pubkey_exposed && !u.loss_rules.length
              span.chip.chip--purple Q-EXPOSED
            span.amt= btc8(u.value_sats)
      else
        .row.row--dotted.row--zero no unspent outputs at this address
