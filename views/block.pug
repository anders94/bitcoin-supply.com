extends layout
include mixins

block content
  .block-pager
    .side
      if pager.prev !== null
        a.jump(href=`/block/${pager.prev}`) ← #{num(pager.prev)}
        span.sub #{num(pager.prevSkipped)} loss-free skipped
      else
        span.jump.disabled ← —
        span.sub start of history
    .side.side--right
      if pager.next !== null
        a.jump(href=`/block/${pager.next}`) #{num(pager.next)} →
        span.sub #{num(pager.nextSkipped)} loss-free skipped
      else
        span.jump.disabled tip →
        span.sub no newer loss

  .block-card
    span.label BLOCK
    span.n= num(blockNum)
    span.meta #{dateTimeUtc(block.block_timestamp)} · #{num(block.tx_count)} TXS
    .removed
      span.label REMOVED IN THIS BLOCK
      span.amt −#{btc8(removedTotal)}

  section.section.section--tight
    .section-head
      span.label MINER LOSS · RULE 002
      span.section-value.section-value--red(style='font-size:11px') −#{btc8(minerLoss)}
    .desc(style='font-size:10.5px') Supply and fees the miner was entitled to but never took — this coin was simply never created.
    .rows(style='font-size:10px')
      .row.row--dotted
        span.k subsidy allowed
        span= btc8(subsidy)
      .row.row--dotted
        span.k fees available
        span= btc8(fees)
      .row.row--dotted
        span.k coinbase claimed
        span= btc8(claimed)
      if minerLoss !== '0'
        .row.row--dotted(style='font-weight:600;color:var(--red)')
          span underclaimed
          span −#{btc8(minerLoss)}
      else
        .row.row--dotted.row--zero full entitlement claimed — no miner loss

  section.section.section--tight
    .section-head
      span.label TRANSACTIONAL LOSS
      span.section-value.section-value--red(style='font-size:11px') −#{btc8(txLoss)}
    .desc(style='font-size:10.5px') Existing coin spent to conditions that make it unspendable — OP_RETURN, invalid scripts, burns.
    .rows(style='font-size:10px')
      if lossUtxos.length
        each u in lossUtxos
          .event-row
            a.txid(href=`/transaction/${u.tx_hash}`)
              +ident(u.tx_hash, shortHash(u.tx_hash))
            span.yr vout #{u.output_index}
            span.chip(class=ruleCategory(u.loss_rules[0]) === 'probable' ? 'chip--amber' : 'chip--red')= ruleChip(u.loss_rules[0])
            span.amt.amt--red −#{btc8(u.value_sats)}
      else
        .row.row--dotted.row--zero no transactional loss in this block

  .tagline A loss explorer, not a block explorer — only blocks that remove coin are stops.
