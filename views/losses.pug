extends layout

block content
  .page-head-row
    .page-head
      span.label LOSS HISTORY
      span.big #{num(totalEvents)} events
    span.aside newest first

  div(style='display:flex;gap:6px;flex-wrap:wrap')
    each ch in chips
      a.chip-btn(
        class=(ch.id === 'ALL' ? !filterRule : filterRule === ch.id) ? 'active' : ''
        href=ch.id === 'ALL' ? '/losses' : `/losses?rule=${ch.id}`
      )= ch.id

  .rows
    each l in losses
      .loss-item
        .line1
          if l.is_block
            a.hash-link(href=`/block/${l.block_number}`) block #{num(l.block_number)}
            span.chip.chip--red= ruleChip('002')
          else
            a.hash-link(href=`/transaction/${l.tx_hash}`)= shortHash(l.tx_hash)
            span.chip(class=ruleCategory(l.loss_rules[0]) === 'probable' ? 'chip--amber' : 'chip--red')= ruleChip(l.loss_rules[0])
          span.amt.amt--red(style='flex:1;text-align:right;font-weight:600;color:var(--red)') −#{btc8(l.value_sats)}
        .line2
          span BLOCK #{num(l.block_number)}
          span= dateUtc(l.block_timestamp)

  .pager
    if page > 1
      a(href=`/losses?page=${page - 1}${filterRule ? '&rule=' + filterRule : ''}`) ← PREV
    else
      span.disabled ← PREV
    span.mid PAGE #{num(page)} OF #{num(totalPages)}
    if page < totalPages
      a(href=`/losses?page=${page + 1}${filterRule ? '&rule=' + filterRule : ''}`) NEXT →
    else
      span.disabled NEXT →
